{
  "name": "moonmoon-rs-js",
  "private": true,
  "type": "module",
  "description": "Test harness for static/lib/* pure helpers used by player.js and sync.js (uses bun's native test runner).",
  "scripts": {
    "check": "bun run format:check && bun test && bun run check:js",
    "check:js": "tsc --noEmit",
    "test": "bun test",
    "format": "prettier --write \"static/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"static/**/*.js\" \"tests/**/*.js\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": "prettier --write"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "3.8.3",
    "typescript": "^6.0.3"
  }
}
